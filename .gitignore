## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
bin/
obj/
out/

# Visual Studio
.vs/
*.user
*.suo

# NuGet
packages/
*.nupkg
*.snupkg

# Logs
*.log

# Temporary files
*.tmp
*.cache
*.db

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

# DotCover
*.dotCover

# Backup & autosave
*.bak
*.orig

# OS-specific
.DS_Store
Thumbs.db
